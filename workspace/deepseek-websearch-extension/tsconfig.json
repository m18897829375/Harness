{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "types": ["chrome"]
  },
  "include": [
    "*.js",
    "background/*.js",
    "popup/*.js",
    "utils/*.js",
    "inject/*.js"
  ],
  "exclude": [
    "node_modules"
  ]
}
